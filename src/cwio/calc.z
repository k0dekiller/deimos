use picoease as raw
use sleep_ms from time

read = raw.read
write = raw.write
init = raw.init

er0 = 0x0000

def halt
    global er0
    global pc
    <|"halt"
    raw.pwrite(0x0D, 0x08)
    er0 = raw.pread(0x04)
.

def resume
    <|"resume"
    <|er0
    raw.run(0x0000 | ((er0 >> 8) & 0xFF), 0x0100 | (er0 & 0xFF))
    raw.pwrite(0x0D, 0x00)
    raw.run(0xFE0F, 0xFE8F)
.

def connect
    raw.connect!
    halt!
.